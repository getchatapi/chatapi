# ── Required ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
MASTER_API_KEY=

# ── Server ──────────────────────────────────────────────────────────────────
LISTEN_ADDR=:8080

# ── Database ────────────────────────────────────────────────────────────────
# Use /data/chatapi.db when running in Docker (mounted volume)
DATABASE_DSN=file:chatapi.db?_journal_mode=WAL&_busy_timeout=5000

# ── WebSocket & CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for dev, your domain in prod.
ALLOWED_ORIGINS=*

# ── Rate Limiting ────────────────────────────────────────────────────────────
DEFAULT_RATE_LIMIT=100
WS_MAX_CONNECTIONS_PER_USER=5

# ── Workers ──────────────────────────────────────────────────────────────────
WORKER_INTERVAL=30s
SHUTDOWN_DRAIN_TIMEOUT=10s

# ── Optional: per-tenant webhook (set via tenant config, not env) ────────────
# webhook_url is configured per tenant via the API, not here.
