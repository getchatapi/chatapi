# -----------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------

# Generate with: openssl rand -base64 32
JWT_SECRET=

# Comma-separated allowed origins for browser clients. Use * for local dev.
ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------
# LLM API keys — referenced by managed bots via llm_api_key_env.
# Add a line for each provider you use. The variable name is what you set
# on the bot registration; the value is the actual key.
# -----------------------------------------------------------------------
GEMINI_API_KEY=
OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# Any name works — e.g. MY_CUSTOM_LLM_KEY=

# -----------------------------------------------------------------------
# Webhook — required if you use bots, recommended for push notifications
#
# ChatAPI calls WEBHOOK_URL for two event types:
#   type: "bot.context"    — before every LLM call; your app returns the system prompt
#   type: "message.offline" — when a message arrives for an offline user
#
# WEBHOOK_SECRET signs requests with HMAC-SHA256 (X-ChatAPI-Signature header).
# -----------------------------------------------------------------------
# WEBHOOK_URL=https://yourapp.com/api/chatapi/webhook
# WEBHOOK_SECRET=

# -----------------------------------------------------------------------
# Tuning (optional — defaults shown)
# -----------------------------------------------------------------------
# LISTEN_ADDR=:8080
# DATABASE_DSN=file:./chatapi.db        # local dev default
# DATABASE_DSN=file:/data/chatapi.db    # Docker default (set by the image)
# WS_MAX_CONNECTIONS_PER_USER=5
# WORKER_INTERVAL=30s
# SHUTDOWN_DRAIN_TIMEOUT=10s
# RATE_LIMIT_MESSAGES=10
# RATE_LIMIT_MESSAGES_BURST=20
